# Postgres connection string (Neon or Supabase). Required for Prisma.
DATABASE_URL=

# Auth.js. Generate a secret with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend, for OTP login codes and order confirmation emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL="AutoSutra Shop <orders@shop.autosutra.com>"

# Cloudinary, for product/category image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay. Use test-mode keys until ready to go live.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Analytics 4 (optional for Phase 1).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL, used for absolute links in emails and metadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
